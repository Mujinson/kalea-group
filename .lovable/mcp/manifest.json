  },
  "mcp": {
    "server": {
      "name": "kalea-crm-mcp",
      "version": "0.1.0",
      "title": "Kalēa CRM"
    },
    "tools": [
      {
        "name": "list_leads",
        "title": "List leads",
        "description": "List recent leads from the Kalēa CRM. Optional filters: status, pipeline_stage, search (matches name/email/city), limit (default 25, max 100).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "status": {
              "description": "Filter by lead status (e.g. 'nuovo', 'qualificato').",
              "type": "string"
            },
            "pipeline_stage": {
              "description": "Filter by pipeline stage (e.g. 'cold', 'warm', 'hot').",
              "type": "string"
            },
            "search": {
              "description": "Search term matched against name, email or city.",
              "type": "string"
            },
            "limit": {
              "description": "Max rows to return (default 25).",
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "list_quotes",
        "title": "List quotes",
        "description": "List Kalēa quotes (preventivi). Optional filters: status (draft/sent/accepted/converted/rejected/expired), search (matches quote_number / client_name), limit (default 25, max 100).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "status": {
              "type": "string"
            },
            "search": {
              "type": "string"
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "list_customers",
        "title": "List customers",
        "description": "List Kalēa customers. Optional filters: status, search (matches company_name / first_name / last_name / email), limit (default 25, max 100).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "status": {
              "type": "string"
            },
            "search": {
              "type": "string"
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "list_construction_sites",
        "title": "List construction sites",
        "description": "List Kalēa construction sites (cantieri). Optional filters: status, priority, search (matches title/project_name/city), limit (default 25, max 100).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "status": {
              "type": "string"
            },
            "priority": {
              "type": "string"
            },
            "search": {
              "type": "string"
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "create_lead",
        "title": "Create lead",
        "description": "Create a new lead in the Kalēa CRM. Requires at least name and email.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "idempotentHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "email": {
              "type": "string",
              "format": "email",
              "pattern": "^(?!\\.)(?!.*\\.\\.)([A-Za-z0-9_'+\\-\\.]*)[A-Za-z0-9_+-]@([A-Za-z0-9][A-Za-z0-9\\-]*\\.)+[A-Za-z]{2,}$"
            },
            "phone": {
              "type": "string"
            },
            "city": {
              "type": "string"
            },
            "province": {
              "type": "string"
            },
            "company_name": {
              "type": "string"
            },
            "interest": {
              "description": "Product / service of interest.",
              "type": "string"
            },
            "notes": {
              "type": "string"
            },
            "source": {
              "description": "Lead source, e.g. 'mcp', 'website'. Defaults to 'mcp'.",
              "type": "string"
            }
          },
          "required": [
            "name",
            "email"
          ]
        },
        "outputSchema": null
      }
    ]
  }
